# Copy to .env and fill in.
# .env is gitignored — never commit a real key.

# ---- OpenAI (personality profile + suburb summaries) ----------------------
OPENAI_API_KEY=sk-...
ORBIT_LLM_MODEL=gpt-4o-mini

# ---- Domain API (live Sydney rental listings) -----------------------------
# Sign up at https://developer.domain.com.au/ → create a project → copy the
# OAuth client id + secret here. Leave blank to fall back to mock listings.
DOMAIN_CLIENT_ID=
DOMAIN_CLIENT_SECRET=

# Optional — sensible defaults apply if omitted:
# DOMAIN_SCOPE=api_listings_read
# ORBIT_LISTINGS_CACHE_H=24

# ---- Deploy ---------------------------------------------------------------
# Railway injects PORT automatically — don't set it here. Locally, uvicorn
# defaults to 8000 via `uvicorn api:app --reload --port 8000`.
# On Railway, the start command reads $PORT (see railway.json / Procfile).
